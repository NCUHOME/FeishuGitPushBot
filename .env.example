# 飞书机器人配置
FEISHU_WEBHOOK=https://open.feishu.cn/open-apis/bot/v2/hook/xxxx
FEISHU_SECRET=xxxx
# 可选：如果需要更新已发送的消息、回复评论（话题模式），则需要以下配置
FEISHU_APP_ID=cli_xxxx
FEISHU_APP_SECRET=xxxx
FEISHU_CHAT_ID=xxxx

# GitHub 配置
GITHUB_KEY=xxxx
GITHUB_BOT_USERS=user1,user2

# 数据库配置 (可选：用于存储消息记录以便后续更新或回复，目前支持 SQLite/PostgreSQL/MySQL)
DATABASE_URL=sqlite://feishu.db
